# Dev-time brainstorming / design specs (not for publication)
docs/superpowers/

# Test harness output — per-prompt scaffolds and archived prior runs.
# Both are produced by tests/run-prompt.py. The prompts/, transcripts/,
# run-prompt.py, README.md, and CLAUDE.md under tests/ remain tracked.
tests/[0-9][0-9]-*/
tests/archived/

