// main.cpp — Dear ImGui + GLFW + OpenGL 3 starter template (docking branch).
//
// Generated by the imgui-cpp Claude Code skill. Copy into a new project and
// adjust to taste. Adapted from upstream's examples/example_glfw_opengl3/main.cpp
// with these conventions:
//   - imscoped.hpp scope guards (see assets/imscoped.hpp) for paired calls
//   - C++23 idioms where they don't fight ImGui's C-flavored API
//   - Docking + multi-viewport enabled by default (this is the docking branch)
//   - Per-monitor DPI scaling
//
// Build (CMake): see CMakeLists-glfw-opengl3.txt.template.

#include <imgui.h>
#include <imgui_impl_glfw.h>
#include <imgui_impl_opengl3.h>

#include "imscoped.hpp"

#define GL_SILENCE_DEPRECATION
#include <GLFW/glfw3.h>

#include <cstdio>

// NOTE on diagnostics: we use <cstdio> std::fprintf / std::printf rather
// than C++23 <print>/std::println because <print> requires libstdc++-14
// or libc++-18+, AND a compiler whose ranges-constraint checking is
// compatible with the chosen stdlib. clang 17 against libstdc++-14
// currently fails inside <bits/unicode.h> (LLVM-61763 family). std::fprintf
// is type-checked at compile time via __attribute__((format)) on every
// modern compiler, works on every libstdc++ from C++98 forward, and costs
// nothing in readability for diagnostics. Switch to std::println in your
// own code if your toolchain supports it; the skill keeps templates
// printf-based to keep the bootstrap working everywhere.

namespace {

void glfw_error_callback(int error, const char* description) {
    std::fprintf(stderr, "GLFW Error %d: %s\n", error, description);
}

// Pick a GLSL version per platform. The string is passed to ImGui_ImplOpenGL3_Init;
// it must match the OpenGL context version you create below.
constexpr const char* k_glsl_version =
#if defined(__APPLE__)
    "#version 150";
#else
    "#version 130";
#endif

void apply_window_hints() {
#if defined(__APPLE__)
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 3);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 2);
    glfwWindowHint(GLFW_OPENGL_PROFILE, GLFW_OPENGL_CORE_PROFILE);
    glfwWindowHint(GLFW_OPENGL_FORWARD_COMPAT, GL_TRUE);
#else
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 3);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 0);
#endif
}

}  // namespace

int main() {
    // ---- 1. GLFW init ---------------------------------------------------
    glfwSetErrorCallback(glfw_error_callback);
    if (!glfwInit()) {
        return 1;
    }
    apply_window_hints();

    const float main_scale =
        ImGui_ImplGlfw_GetContentScaleForMonitor(glfwGetPrimaryMonitor());
    GLFWwindow* window = glfwCreateWindow(
        static_cast<int>(1280 * main_scale),
        static_cast<int>(800 * main_scale),
        "Dear ImGui — GLFW + OpenGL 3",
        nullptr, nullptr);
    if (window == nullptr) {
        glfwTerminate();
        return 1;
    }
    glfwMakeContextCurrent(window);
    glfwSwapInterval(1);  // vsync

    // ---- 2. ImGui context + IO config -----------------------------------
    IMGUI_CHECKVERSION();
    ImGui::CreateContext();
    ImGuiIO& io = ImGui::GetIO();
    io.ConfigFlags |= ImGuiConfigFlags_NavEnableKeyboard;
    io.ConfigFlags |= ImGuiConfigFlags_DockingEnable;
    io.ConfigFlags |= ImGuiConfigFlags_ViewportsEnable;
    io.ConfigDpiScaleFonts     = true;   // auto-rescale fonts on monitor DPI change
    io.ConfigDpiScaleViewports = true;   // auto-rescale viewport sizes too

    // ---- 3. Style + DPI baking ------------------------------------------
    ImGui::StyleColorsDark();
    ImGuiStyle& style = ImGui::GetStyle();
    style.ScaleAllSizes(main_scale);
    style.FontScaleDpi = main_scale;
    if (io.ConfigFlags & ImGuiConfigFlags_ViewportsEnable) {
        // Viewport platform windows look identical to regular ones.
        style.WindowRounding = 0.0f;
        style.Colors[ImGuiCol_WindowBg].w = 1.0f;
    }

    // ---- 4. Backends -----------------------------------------------------
    // install_callbacks=true lets ImGui chain GLFW input callbacks.
    // Pass false if you handle GLFW input yourself; you must then forward
    // events via the per-callback ImGui_ImplGlfw_*Callback functions.
    ImGui_ImplGlfw_InitForOpenGL(window, /*install_callbacks=*/true);
    ImGui_ImplOpenGL3_Init(k_glsl_version);

    // ---- 5. (Optional) Load custom fonts --------------------------------
    // Default font is fine to start. Add your own with:
    //   io.Fonts->AddFontFromFileTTF("path/to/font.ttf", 16.0f);
    // ImGui v1.92's font system rebuilds the atlas automatically on
    // NewFrame(); no explicit CreateFontsTexture() call required.

    // ---- 6. Application state -------------------------------------------
    bool show_demo_window = true;
    ImVec4 clear_color{0.10f, 0.12f, 0.14f, 1.00f};

    // ---- 7. Main loop ----------------------------------------------------
    while (!glfwWindowShouldClose(window)) {
        glfwPollEvents();
        // Iconified windows: skip the frame to save power.
        if (glfwGetWindowAttrib(window, GLFW_ICONIFIED) != 0) {
            ImGui_ImplGlfw_Sleep(10);
            continue;
        }

        // Frame begin: backend → ImGui (this exact order)
        ImGui_ImplOpenGL3_NewFrame();
        ImGui_ImplGlfw_NewFrame();
        ImGui::NewFrame();

        // Your UI submission here.
        if (show_demo_window) {
            ImGui::ShowDemoWindow(&show_demo_window);
        }

        // Example: a simple window using imscoped guards.
        if (auto win = ImScoped::Window("Hello, world!")) {
            ImGui::Text("Application: %.1f FPS", io.Framerate);
            ImGui::Checkbox("Show demo window", &show_demo_window);
            ImGui::ColorEdit3("Clear color", &clear_color.x);
        }

        // Frame end: render ImGui's draw data through the GL backend.
        ImGui::Render();

        int display_w = 0, display_h = 0;
        glfwGetFramebufferSize(window, &display_w, &display_h);
        glViewport(0, 0, display_w, display_h);
        glClearColor(clear_color.x * clear_color.w,
                     clear_color.y * clear_color.w,
                     clear_color.z * clear_color.w,
                     clear_color.w);
        glClear(GL_COLOR_BUFFER_BIT);
        ImGui_ImplOpenGL3_RenderDrawData(ImGui::GetDrawData());

        // Multi-viewport: render any platform windows that ImGui created.
        // Save/restore current GL context because platform functions may change it.
        if (io.ConfigFlags & ImGuiConfigFlags_ViewportsEnable) {
            GLFWwindow* backup = glfwGetCurrentContext();
            ImGui::UpdatePlatformWindows();
            ImGui::RenderPlatformWindowsDefault();
            glfwMakeContextCurrent(backup);
        }

        glfwSwapBuffers(window);
    }

    // ---- 8. Shutdown (reverse init order) -------------------------------
    ImGui_ImplOpenGL3_Shutdown();
    ImGui_ImplGlfw_Shutdown();
    ImGui::DestroyContext();
    glfwDestroyWindow(window);
    glfwTerminate();
    return 0;
}
