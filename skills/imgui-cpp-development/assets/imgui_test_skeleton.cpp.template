// imgui_test_skeleton.cpp — imgui_test_engine harness skeleton.
//
// Generated by the imgui-cpp Claude Code skill. Drop into a test target that
// links against ImGui (built with -DIMGUI_ENABLE_TEST_ENGINE) and the
// imgui_test_engine static library (see CMakeLists template).
//
// Two ways to use this skeleton:
//   1. GUI mode (default): start the test engine alongside your normal main()
//      so a "Test Engine" window appears in the running app — interactive,
//      great for authoring tests.
//   2. Headless mode (CI): pass --headless on the command line; the test
//      engine runs the registered tests without a window and exits with
//      non-zero on failure.
//
// imgui_test_engine talks to the running ImGui context. It does NOT validate
// pixel-level rendering; it tests interaction logic and UI state. For visual
// regression testing you need a separate pipeline.
//
// Reference: https://github.com/ocornut/imgui_test_engine and
// vendor/imgui_test_engine/imgui_test_engine/imgui_te_engine.h.

#include <imgui.h>
#include <imgui_te_engine.h>
#include <imgui_te_context.h>
#include <imgui_te_ui.h>

#include <cstdio>
#include <cstring>
#include <print>

namespace tests {

// ---- Example test ---------------------------------------------------------
// Click "Hello, world!" → "Counter" button N times, expect counter == N.
//
// Pattern: GuiFunc submits the UI under test (using shared state), TestFunc
// drives interactions and asserts. The macro IM_CHECK aborts the test on
// failure with file:line context.
struct CounterState {
    int counter = 0;
};

void register_counter_test(ImGuiTestEngine* engine, CounterState* state) {
    ImGuiTest* t = IM_REGISTER_TEST(engine, "demo", "counter_increments");

    t->GuiFunc = [](ImGuiTestContext* ctx) {
        auto* s = static_cast<CounterState*>(ctx->Test->UserData);
        ImGui::SetNextWindowSize(ImVec2(300, 150), ImGuiCond_Once);
        ImGui::Begin("Hello, world!");
        if (ImGui::Button("Counter")) {
            s->counter++;
        }
        ImGui::Text("counter = %d", s->counter);
        ImGui::End();
    };

    t->TestFunc = [](ImGuiTestContext* ctx) {
        auto* s = static_cast<CounterState*>(ctx->Test->UserData);
        s->counter = 0;

        ctx->SetRef("Hello, world!");
        ctx->ItemClick("Counter");
        ctx->ItemClick("Counter");
        ctx->ItemClick("Counter");

        IM_CHECK_EQ(s->counter, 3);
    };

    t->UserData = state;
}

// Add more register_xxx_test() functions as you go and call them from main().

}  // namespace tests

// ---------------------------------------------------------------------------
// main() — replace your normal main() with this for the test build.
// ---------------------------------------------------------------------------
int main(int argc, char** argv) {
    bool headless = false;
    const char* filter = nullptr;
    for (int i = 1; i < argc; ++i) {
        if (std::strcmp(argv[i], "--headless") == 0)        headless = true;
        else if (std::strcmp(argv[i], "--filter") == 0 && i + 1 < argc) filter = argv[++i];
    }

    // ---- ImGui context ----------------------------------------------------
    IMGUI_CHECKVERSION();
    ImGui::CreateContext();
    ImGuiIO& io = ImGui::GetIO();
    io.DisplaySize  = ImVec2(1280, 720);
    io.DeltaTime    = 1.0f / 60.0f;

    // For headless mode, we don't need a real backend; the test engine
    // exercises ImGui purely through the IO interface.
    if (!headless) {
        // In GUI mode, you would normally bind your usual platform/renderer
        // backends here (GLFW + OpenGL3, etc.) so the Test Engine window is
        // visible. See main_glfw_opengl3.cpp.template for the standard setup.
        std::println("note: GUI mode requested but no backend is wired up in this skeleton. Bind GLFW+OpenGL3 here for an interactive test runner.");
    }

    // ---- Test engine ------------------------------------------------------
    ImGuiTestEngine* engine = ImGuiTestEngine_CreateContext();
    ImGuiTestEngineIO& te_io = ImGuiTestEngine_GetIO(engine);
    te_io.ConfigVerboseLevel       = ImGuiTestVerboseLevel_Info;
    te_io.ConfigVerboseLevelOnError = ImGuiTestVerboseLevel_Debug;
    te_io.ConfigRunSpeed = headless ? ImGuiTestRunSpeed_Fast : ImGuiTestRunSpeed_Normal;
    te_io.ConfigStopOnError = false;
    te_io.ConfigSavedSettings = false;

    ImGuiTestEngine_Start(engine, ImGui::GetCurrentContext());
    ImGuiTestEngine_InstallDefaultCrashHandler();

    // ---- Register tests ---------------------------------------------------
    static tests::CounterState counter_state;
    tests::register_counter_test(engine, &counter_state);

    // ---- Run / drive ------------------------------------------------------
    if (headless) {
        ImGuiTestEngine_QueueTests(engine, ImGuiTestGroup_Tests, filter,
                                   ImGuiTestRunFlags_RunFromCommandLine);
        // Pump frames until queue empties.
        while (ImGuiTestEngine_IsTestQueueEmpty(engine) == false) {
            ImGui::NewFrame();
            ImGuiTestEngine_ShowTestEngineWindows(engine, nullptr);
            ImGui::Render();
            ImGuiTestEngine_PostSwap(engine);
        }
        ImGuiTestEngineResultSummary summary;
        ImGuiTestEngine_GetResultSummary(engine, &summary);
        std::println("tests: {} passed, {} failed",
                     summary.CountTested - summary.CountSuccess > 0
                         ? summary.CountSuccess : summary.CountTested,
                     summary.CountTested - summary.CountSuccess);
        ImGuiTestEngine_Stop(engine);
        ImGuiTestEngine_DestroyContext(engine);
        ImGui::DestroyContext();
        return summary.CountTested == summary.CountSuccess ? 0 : 1;
    }

    // GUI mode: integrate your platform/renderer loop here, calling
    // ImGuiTestEngine_PostSwap(engine) once per swapped frame so the engine
    // can step its coroutine. Use the Test Engine window (rendered by
    // ImGuiTestEngine_ShowTestEngineWindows) to author and run tests
    // interactively.
    std::println("GUI mode: integrate with your platform/renderer loop and call ImGuiTestEngine_PostSwap(engine) per frame.");
    ImGuiTestEngine_Stop(engine);
    ImGuiTestEngine_DestroyContext(engine);
    ImGui::DestroyContext();
    return 0;
}
